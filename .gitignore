# Recorded TUI demos (large binary blobs; recordings live in docs/recordings/)
docs/recordings/*.gif
docs/recordings/*.webm
docs/recordings/*.mp4
docs/recordings/*.cast

# Test output
tests/node_modules/
tests/playwright-report/
tests/test-results/
tests/.last-run.json

# Daemon state (any path under ~/.claude/illo-sidebar/ or a local dev dir)
state.json
history.jsonl
daemon.port
daemon.pid
daemon.log
pending_resume.json
vcr-current.jsonl
browser-profile/
vcr/

# Editor / OS
.DS_Store
*.swp
*.log
.vscode/
.idea/

# Claude Code per-project state (session, transcripts, etc.)
# Ignore everything under .claude/ EXCEPT the agentic harness (tracked
# skills + agent role briefs). Note: gitignore re-includes don't work if a
# parent directory is fully excluded, so we exclude .claude/* (one level)
# and re-include the two harness directories explicitly.
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
npm-debug.log*
